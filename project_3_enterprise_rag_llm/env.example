# Project 3 RAG — production env

# Infra (defaults match ds_platform/infra docker-compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=dsplatform
POSTGRES_PASSWORD=dsplatform_dev
POSTGRES_DB=dsplatform
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev
MLFLOW_TRACKING_URI=http://localhost:5000

# Qdrant (vector store)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# LLM (OpenAI-compatible: OpenAI, vLLM, etc.)
RAG_LLM_BASE_URL=https://api.openai.com/v1
RAG_LLM_API_KEY=sk-...
RAG_LLM_MODEL=gpt-4o-mini
# RAG_LLM_TEMPERATURE=0.2

# Celery (async eval / optional batch)
CELERY_BROKER_URL=redis://:redis_dev@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_dev@localhost:6379/0
