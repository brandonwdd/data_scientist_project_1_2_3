# Environment
ENVIRONMENT=development

# PostgreSQL Configuration
POSTGRES_USER=dsplatform
POSTGRES_PASSWORD=dsplatform_dev
POSTGRES_DB=dsplatform
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev
REDIS_DB=0

# MLflow Configuration
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://dsplatform:dsplatform_dev@localhost:5432/dsplatform
# For local dev, use file:// path (absolute or relative to mlflow container)
MLFLOW_ARTIFACT_ROOT=file:///mlflow/artifacts
# For production, use S3:
# MLFLOW_ARTIFACT_ROOT=s3://mlflow-artifacts

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Application Configuration
LOG_LEVEL=DEBUG
API_HOST=0.0.0.0
API_PORT=8000

# Feature Store Configuration
FEATURE_STORE_OFFLINE_PATH=s3://lake/features
FEATURE_STORE_ONLINE_TTL_HOURS=24

# Async Queue Configuration
CELERY_BROKER_URL=redis://:redis_dev@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_dev@localhost:6379/0

# S3 Configuration (for production artifacts)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=ds-platform-artifacts

# Optional: Monitoring & Alerting
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# ALERTMANAGER_URL=http://alertmanager:9093
