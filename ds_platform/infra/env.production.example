# ============================================
# ML Platform - Production Environment
# ============================================
# Copy this file to .env.production and modify as needed

# Environment
ENVIRONMENT=production

# PostgreSQL Configuration
# IMPORTANT: Change these values in production!
POSTGRES_USER=mlplatform_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=mlplatform
POSTGRES_PORT=5432
POSTGRES_HOST=postgres-service

# Redis Configuration
REDIS_HOST=redis-service
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD
REDIS_DB=0

# MLflow Configuration
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow-service:5000
MLFLOW_BACKEND_STORE_URI=postgresql://mlplatform_prod:CHANGE_ME_STRONG_PASSWORD@postgres-service:5432/mlplatform
# Production: Use S3 or other object storage
MLFLOW_ARTIFACT_ROOT=s3://ds-platform-artifacts-prod

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Application Configuration
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Feature Store Configuration
FEATURE_STORE_OFFLINE_PATH=s3://lake-prod/features
FEATURE_STORE_ONLINE_TTL_HOURS=24

# Async Queue Configuration
CELERY_BROKER_URL=redis://:CHANGE_ME_STRONG_PASSWORD@redis-service:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_STRONG_PASSWORD@redis-service:6379/0

# S3 Configuration (Required for production)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=us-east-1
S3_BUCKET=ds-platform-artifacts-prod

# Monitoring & Alerting (Required for production)
SLACK_WEBHOOK_URL=CHANGE_ME
ALERTMANAGER_URL=http://alertmanager:9093

# Security
ALLOWED_ORIGINS=https://your-domain.com
API_KEY_SECRET=CHANGE_ME_STRONG_SECRET

# Performance Tuning
WORKER_CONCURRENCY=4
MAX_WORKERS=8
REQUEST_TIMEOUT=30
